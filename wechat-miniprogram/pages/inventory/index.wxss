.inventory-page .custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mode-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  color: #345f55;
  font-size: 24rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, .9);
}

.search-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 92rpx;
  margin-top: 22rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(81, 119, 101, .12);
  border-radius: 26rpx;
  color: #345f55;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 10rpx 28rpx rgba(52, 95, 85, .08);
}

.search-card input {
  flex: 1;
  color: #263a34;
  font-size: 28rpx;
}

.search-card button {
  color: #345f55;
  font-size: 26rpx;
  font-weight: 900;
}

.chip-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.chip-scroll.compact {
  margin-top: 14rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 116rpx;
  height: 62rpx;
  margin-right: 14rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #879691;
  font-size: 25rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, .9);
}

.chip.sort {
  min-width: 150rpx;
}

.chip.active {
  color: #fff;
  background: linear-gradient(135deg, #517765, #587f96);
  box-shadow: 0 10rpx 26rpx rgba(52, 95, 85, .18);
}

.inventory-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.inventory-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.inventory-list.card {
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.inventory-list.list {
  grid-template-columns: 1fr;
}
