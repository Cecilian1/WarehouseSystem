.custom-nav {
  display: flex;
  align-items: center;
}

.search-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 88rpx;
  margin-top: 22rpx;
  padding: 0 22rpx;
  border-radius: 30rpx;
  color: #345f55;
  background: rgba(255, 255, 255, .82);
}

.search-card input {
  flex: 1;
  color: #263a34;
  font-size: 28rpx;
}

.type-row {
  margin: 22rpx 0;
  white-space: nowrap;
}

.type-row button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 64rpx;
  margin-right: 14rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #879691;
  font-size: 25rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, .72);
}

.type-row .active {
  color: #fff;
  background: linear-gradient(135deg, #517765, #587f96);
}

.timeline {
  display: grid;
  gap: 18rpx;
}

.record-item {
  position: relative;
  padding-left: 52rpx;
}

.record-item::before {
  position: absolute;
  left: 21rpx;
  top: 58rpx;
  bottom: -22rpx;
  border-left: 2rpx solid rgba(81, 119, 101, .18);
  content: "";
}

.record-dot {
  position: absolute;
  left: 0;
  top: 26rpx;
  display: grid;
  width: 44rpx;
  height: 44rpx;
  place-items: center;
  border: 4rpx solid #fff;
  border-radius: 50%;
  color: #fff;
  background: #517765;
  box-shadow: 0 0 0 8rpx rgba(81, 119, 101, .1);
}

.record-dot.outbound {
  background: #587f96;
}

.record-dot.manual {
  background: #7b6cc8;
}

.record-head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.record-title {
  color: #263a34;
  font-size: 29rpx;
  font-weight: 900;
}

.record-time,
.record-meta {
  color: #879691;
  font-size: 23rpx;
}

.record-detail {
  margin-top: 10rpx;
  color: #4b635d;
  font-size: 27rpx;
  font-weight: 700;
}

.record-meta {
  margin-top: 8rpx;
}
