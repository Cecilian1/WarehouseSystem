<view class="page-shell home-page" style="--status-top: {{statusTop}}px; --nav-height: {{navHeight}}px;">
  <view class="home-hero fade-up">
    <view class="custom-nav" style="padding-top: {{statusTop}}px;">
      <view>
        <view class="hello">晚上好</view>
        <view class="hero-title">芯鲜管家</view>
      </view>
    </view>
    <view class="hero-copy">{{overview.greeting || '正在读取冰箱状态'}}</view>
  </view>

  <glass-card wx:if="{{overview}}" tone="light" padding="normal" hover bindtap="goDevice">
    <view class="device-card">
      <view>
        <view class="card-label">当前设备</view>
        <view class="card-title">{{overview.device.name}}</view>
        <view class="card-sub">最近同步 {{overview.device.lastSync}} · {{overview.device.code}}</view>
      </view>
      <status-tag label="{{overview.device.state === 'online' ? '在线' : overview.device.state === 'warning' ? '需关注' : '离线'}}" tone="{{overview.device.state}}" icon="device" />
    </view>
    <view class="device-grid">
      <view><i class="status-dot"></i><text>摄像头：{{overview.device.cameraStatus}}</text></view>
      <view><i class="status-dot"></i><text>传感器：{{overview.device.sensorStatus}}</text></view>
    </view>
  </glass-card>

  <glass-card wx:if="{{overview}}" tone="{{overview.environment.state === '适宜' ? 'deep' : 'warn'}}" padding="normal" hover bindtap="goEnvironment">
    <view class="env-card">
      <view>
        <view class="env-title">冰箱环境</view>
        <view class="env-desc">{{overview.environment.description}}</view>
      </view>
      <view class="env-state">{{overview.environment.state}}</view>
    </view>
    <view class="env-values">
      <view>
        <small>温度</small>
        <text>{{overview.environment.temperature}}</text>
        <small>°C</small>
      </view>
      <view>
        <small>湿度</small>
        <text>{{overview.environment.humidity}}</text>
        <small>%RH</small>
      </view>
    </view>
  </glass-card>

  <view class="section-head">
    <view class="section-head__title">新鲜度概览</view>
    <button class="section-head__more" bindtap="go" data-url="/pages/inventory/index">查看库存</button>
  </view>
  <glass-card wx:if="{{overview}}" padding="normal">
    <view class="fresh-stack">
      <view wx:for="{{freshnessBars}}" wx:key="key" class="fresh-segment" style="width: {{item.width}}%; background: {{item.color}};"></view>
    </view>
    <view class="fresh-legend">
      <view wx:for="{{freshnessBars}}" wx:key="key">
        <i style="background: {{item.color}};"></i>
        <text>{{item.label}}</text>
        <b>{{item.value}}</b>
      </view>
    </view>
  </glass-card>

  <view class="section-head">
    <view class="section-head__title">今日提醒</view>
    <button class="section-head__more" bindtap="go" data-url="/pages/alerts/index">全部</button>
  </view>
  <view class="reminder-list">
    <glass-card wx:for="{{overview.reminders}}" wx:key="id" padding="small" hover>
      <button class="reminder-item" bindtap="goMessage" data-id="{{item.id}}">
        <view class="reminder-icon {{item.level}}"><x-icon type="alert" size="{{34}}" /></view>
        <view>
          <view class="reminder-title">{{item.title}}</view>
          <view class="reminder-desc">{{item.description}}</view>
        </view>
      </button>
    </glass-card>
  </view>

  <view class="section-head">
    <view class="section-head__title">智能建议</view>
  </view>
  <glass-card padding="normal">
    <view class="suggestion" wx:for="{{overview.suggestions}}" wx:key="*this">
      <view class="suggestion-dot"></view>
      <text>{{item}}</text>
    </view>
  </glass-card>

  <view class="quick-grid">
    <button wx:for="{{overview.quickActions}}" wx:key="title" class="quick-card tap-scale" bindtap="go" data-url="{{item.path}}">
      <x-icon type="{{item.icon}}" size="{{42}}" />
      <text>{{item.title}}</text>
    </button>
  </view>
</view>
