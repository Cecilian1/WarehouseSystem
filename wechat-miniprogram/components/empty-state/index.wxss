.empty-state {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  min-height: 520rpx;
  padding: 52rpx 28rpx;
  text-align: center;
}

.empty-visual {
  position: relative;
  width: 210rpx;
  height: 180rpx;
}

.icon-wrap {
  position: absolute;
  left: 50%;
  top: 50%;
  display: grid;
  width: 140rpx;
  height: 140rpx;
  place-items: center;
  border: 1rpx solid rgba(255, 255, 255, .86);
  border-radius: 44rpx;
  color: #517765;
  background: rgba(255, 255, 255, .7);
  box-shadow: 0 18rpx 42rpx rgba(52, 95, 85, .14);
  transform: translate(-50%, -50%);
}

.leaf {
  position: absolute;
  width: 90rpx;
  height: 52rpx;
  border-radius: 60rpx 0 60rpx 0;
  background: rgba(88, 127, 150, .16);
}

.leaf-a {
  left: 12rpx;
  top: 18rpx;
  transform: rotate(-22deg);
}

.leaf-b {
  right: 12rpx;
  bottom: 20rpx;
  background: rgba(81, 119, 101, .18);
  transform: rotate(26deg);
}

.empty-title {
  color: #263a34;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-desc {
  max-width: 520rpx;
  margin-top: 12rpx;
  color: #879691;
  font-size: 26rpx;
  line-height: 1.55;
}

.empty-button {
  width: 320rpx;
  margin-top: 28rpx;
}
