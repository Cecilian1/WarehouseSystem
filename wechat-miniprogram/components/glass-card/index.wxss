.glass-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(81, 119, 101, .12);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 12rpx 34rpx rgba(52, 95, 85, .08);
  backdrop-filter: blur(12rpx);
}

.glass-card::before {
  display: none;
}

.padding-normal {
  padding: 28rpx;
}

.padding-small {
  padding: 20rpx;
}

.padding-none {
  padding: 0;
}

.tone-deep {
  color: #fff;
  border-color: rgba(255, 255, 255, .2);
  background: linear-gradient(135deg, #517765, #6f97a6);
  box-shadow: 0 18rpx 42rpx rgba(52, 95, 85, .16);
}

.tone-warn {
  color: #fff;
  border-color: rgba(255, 255, 255, .28);
  background: linear-gradient(135deg, #e59a45, #d96459);
  box-shadow: 0 18rpx 42rpx rgba(217, 100, 89, .18);
}

.tap-scale {
  transition: transform .18s ease, opacity .18s ease;
}

.tap-scale:active {
  transform: scale(.98);
  opacity: .88;
}
