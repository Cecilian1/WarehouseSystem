.produce-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
}

.action-rail {
  position: absolute;
  inset: 0 0 0 auto;
  display: flex;
  align-items: stretch;
  width: 252rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #517765, #587f96);
}

.action-rail button {
  display: flex;
  align-items: center;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.action-rail .danger {
  background: rgba(203, 98, 89, .34);
}

.produce-card {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 20rpx;
  min-height: 170rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(81, 119, 101, .12);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 10rpx 28rpx rgba(52, 95, 85, .08);
  transition: transform .18s ease;
}

.is-open .produce-card {
  transform: translateX(-252rpx);
}

.produce-visual {
  position: relative;
  display: grid;
  width: 130rpx;
  height: 130rpx;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 28rpx;
  background: rgba(81, 119, 101, .07);
  border: 1rpx solid rgba(81, 119, 101, .1);
}

.produce-visual::after {
  position: absolute;
  inset: 18rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, .7), transparent 64%);
  content: "";
}

.food {
  position: relative;
  z-index: 1;
  width: 66rpx;
  height: 66rpx;
  background: var(--food-color);
  box-shadow: inset 0 8rpx 16rpx rgba(255, 255, 255, .22), 0 12rpx 24rpx rgba(0, 0, 0, .1);
}

.food-apple,
.food-tomato,
.food-orange {
  border-radius: 48% 52% 50% 50%;
}

.food-banana {
  width: 76rpx;
  height: 48rpx;
  border-radius: 0 0 70rpx 70rpx;
  transform: rotate(-24deg);
}

.food-berry {
  border-radius: 50% 50% 42% 42%;
  clip-path: polygon(50% 0, 86% 18%, 100% 52%, 74% 100%, 25% 100%, 0 52%, 15% 18%);
}

.food-cucumber {
  width: 86rpx;
  height: 34rpx;
  border-radius: 999rpx;
  transform: rotate(-16deg);
}

.food-leaf,
.food-lettuce {
  width: 78rpx;
  height: 54rpx;
  border-radius: 70rpx 0 70rpx 0;
  transform: rotate(-18deg);
}

.food-carrot {
  width: 50rpx;
  height: 82rpx;
  clip-path: polygon(18% 0, 82% 0, 56% 100%);
  transform: rotate(28deg);
}

.food-broccoli {
  width: 82rpx;
  height: 70rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 25% 30%, #a9d9b7 0 18%, transparent 19%), radial-gradient(circle at 52% 25%, #5d9b73 0 22%, transparent 23%), radial-gradient(circle at 74% 42%, #4b815f 0 20%, transparent 21%), #3d6f4d;
}

.produce-main {
  min-width: 0;
  flex: 1;
}

.produce-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.produce-name {
  color: #263a34;
  font-size: 31rpx;
  font-weight: 900;
}

.produce-meta,
.produce-foot {
  color: #879691;
  font-size: 23rpx;
}

.produce-meta {
  margin-top: 6rpx;
}

.produce-info {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  color: #4b635d;
  font-size: 24rpx;
  font-weight: 700;
}

.fresh-line {
  height: 10rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(81, 119, 101, .1);
}

.fresh-line view {
  height: 100%;
  border-radius: inherit;
}

.produce-foot {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 14rpx;
}

.score-ring {
  display: grid;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  place-items: center;
  border: 8rpx solid rgba(52, 95, 85, .08);
  border-top-color: var(--score-color);
  border-right-color: var(--score-color);
  border-radius: 50%;
}

.score-ring text {
  color: #263a34;
  font-size: 22rpx;
  font-weight: 900;
}

.mode-card .produce-card {
  display: block;
  min-height: auto;
  padding: 18rpx;
}

.mode-card .action-rail {
  display: none;
}

.mode-card.is-open .produce-card {
  transform: none;
}

.mode-card .produce-visual {
  width: 100%;
  height: 168rpx;
  border-radius: 26rpx;
}

.mode-card .food {
  width: 86rpx;
  height: 86rpx;
}

.mode-card .food-banana {
  width: 110rpx;
  height: 62rpx;
}

.mode-card .food-cucumber {
  width: 116rpx;
  height: 44rpx;
}

.mode-card .food-leaf,
.mode-card .food-lettuce {
  width: 106rpx;
  height: 70rpx;
}

.mode-card .food-carrot {
  width: 62rpx;
  height: 108rpx;
}

.mode-card .food-broccoli {
  width: 104rpx;
  height: 88rpx;
}

.mode-card .produce-main {
  margin-top: 16rpx;
}

.mode-card .score-ring {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, .78);
}

.mode-card .produce-head {
  display: block;
  padding-right: 0;
}

.mode-card .produce-status {
  display: inline-block;
  margin-top: 10rpx;
}

.mode-card .produce-info {
  gap: 8rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
}

.mode-card .produce-info text {
  padding: 5rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(81, 119, 101, .08);
}

.mode-card .produce-info text:nth-child(3) {
  display: none;
}

.mode-card .produce-foot {
  display: block;
  margin-top: 12rpx;
}

.mode-card .produce-foot text:last-child {
  display: none;
}

.mode-list .produce-card {
  align-items: center;
  min-height: 132rpx;
  padding: 18rpx;
  gap: 16rpx;
  border-radius: 24rpx;
}

.mode-list .produce-visual {
  width: 86rpx;
  height: 86rpx;
  border-radius: 22rpx;
}

.mode-list .food {
  width: 46rpx;
  height: 46rpx;
}

.mode-list .food-banana {
  width: 58rpx;
  height: 34rpx;
}

.mode-list .food-cucumber {
  width: 64rpx;
  height: 26rpx;
}

.mode-list .food-leaf,
.mode-list .food-lettuce {
  width: 60rpx;
  height: 40rpx;
}

.mode-list .food-carrot {
  width: 34rpx;
  height: 62rpx;
}

.mode-list .food-broccoli {
  width: 62rpx;
  height: 52rpx;
}

.mode-list .produce-head {
  display: block;
}

.mode-list .produce-name {
  font-size: 29rpx;
}

.mode-list .produce-status {
  display: none;
}

.mode-list .produce-info {
  margin-top: 8rpx;
  font-size: 23rpx;
}

.mode-list .fresh-line,
.mode-list .produce-foot,
.mode-list .score-ring {
  display: none;
}
