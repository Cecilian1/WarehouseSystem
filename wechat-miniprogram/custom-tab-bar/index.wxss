.tab-safe {
  position: fixed;
  z-index: 80;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
}

.tab-bar {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
  min-height: 104rpx;
  padding: 8rpx 16rpx calc(10rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(81, 119, 101, .12);
  border-radius: 26rpx 26rpx 0 0;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 -8rpx 24rpx rgba(52, 95, 85, .08);
  backdrop-filter: blur(12rpx);
  pointer-events: auto;
}

.tab-item {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  min-height: 82rpx;
  color: #78908f;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.tab-icon {
  display: grid;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  border-radius: 18rpx;
}

.tab-item.active {
  color: #345f55;
}

.tab-item.active .tab-icon {
  background: rgba(81, 119, 101, .1);
}

.tab-item.center {
  transform: none;
}

.tab-item.center .tab-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #517765, #587f96);
  box-shadow: 0 8rpx 20rpx rgba(52, 95, 85, .2);
}

.tab-item.center text {
  color: #345f55;
  font-size: 22rpx;
}
